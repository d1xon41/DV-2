{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/extinctions.csv"
    },
    "transform": [
        {
            "fold": [
                "mammals",
                "birds",
                "reptiles",
                "frogs"
            ],
            "as": [
                "group",
                "extinctions"
            ]
        },
        {
            "aggregate": [
                {
                    "op": "sum",
                    "field": "extinctions",
                    "as": "total"
                }
            ],
            "groupby": [
                "group"
            ]
        }
    ],
    "params": [
        {
            "name": "group_select",
            "select": {
                "type": "point",
                "fields": [
                    "group"
                ]
            }
        }
    ],
    "mark": {
        "type": "arc",
        "innerRadius": 60,
        "outerRadius": 140,
        "cursor": "pointer"
    },
    "encoding": {
        "theta": {
            "field": "total",
            "type": "quantitative"
        },
        "color": {
            "field": "group",
            "type": "nominal",
            "title": "Animal Group",
            "scale": {
                "domain": [
                    "mammals",
                    "birds",
                    "reptiles",
                    "frogs"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d7a3a",
                    "#66bb6a",
                    "#a5d6a7"
                ]
            }
        },
        "opacity": {
            "condition": {
                "param": "group_select",
                "value": 1
            },
            "value": 0.3
        },
        "tooltip": [
            {
                "field": "group",
                "title": "Animal Group"
            },
            {
                "field": "total",
                "title": "Total Extinctions Since 1800s"
            }
        ]
    },
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}