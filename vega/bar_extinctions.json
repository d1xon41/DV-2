{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 350,
    "height": 350,
    "data": {
        "url": "data/extinctions.csv"
    },
    "transform": [
        {
            "fold": [
                "mammals",
                "birds",
                "reptiles",
                "frogs"
            ],
            "as": [
                "group",
                "extinctions"
            ]
        },
        {
            "aggregate": [
                {
                    "op": "sum",
                    "field": "extinctions",
                    "as": "total"
                }
            ],
            "groupby": [
                "group"
            ]
        }
    ],
    "params": [
        {
            "name": "group_select",
            "select": {
                "type": "point",
                "fields": [
                    "group"
                ]
            }
        }
    ],
    "layer": [
        {
            "mark": {
                "type": "arc",
                "innerRadius": 20,
                "stroke": "#ffffff",
                "strokeWidth": 2,
                "cursor": "pointer"
            },
            "encoding": {
                "theta": {
                    "field": "total",
                    "type": "quantitative",
                    "stack": true
                },
                "radius": {
                    "field": "total",
                    "type": "quantitative",
                    "scale": {
                        "rangeMin": 60,
                        "rangeMax": 160
                    }
                },
                "color": {
                    "field": "group",
                    "type": "nominal",
                    "title": "Animal Group",
                    "scale": {
                        "domain": [
                            "mammals",
                            "birds",
                            "reptiles",
                            "frogs"
                        ],
                        "range": [
                            "#1a4a2e",
                            "#2d7a3a",
                            "#66bb6a",
                            "#a5d6a7"
                        ]
                    }
                },
                "opacity": {
                    "condition": {
                        "param": "group_select",
                        "value": 1
                    },
                    "value": 0.3
                },
                "tooltip": [
                    {
                        "field": "group",
                        "title": "Animal Group"
                    },
                    {
                        "field": "total",
                        "title": "Total Extinctions Since 1800s"
                    }
                ]
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "axis": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "gridColor": "#d4c9a8"
        },
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}