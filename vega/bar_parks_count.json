{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 350,
    "height": 350,
    "background": "#ede3cc",
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "transform": [
        {
            "calculate": "1",
            "as": "equal_sector"
        }
    ],
    "params": [
        {
            "name": "state_select",
            "select": {
                "type": "point",
                "fields": [
                    "state"
                ]
            }
        }
    ],
    "mark": {
        "type": "arc",
        "innerRadius": 25,
        "stroke": "#ede3cc",
        "strokeWidth": 2,
        "cursor": "pointer"
    },
    "encoding": {
        "theta": {
            "field": "equal_sector",
            "type": "quantitative",
            "stack": true
        },
        "radius": {
            "field": "number_of_parks",
            "type": "quantitative",
            "scale": {
                "rangeMin": 25,
                "rangeMax": 155
            }
        },
        "color": {
            "field": "state",
            "type": "nominal",
            "scale": {
                "domain": [
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d6a3e",
                    "#3d8a50",
                    "#4da062",
                    "#66bb6a",
                    "#81c784",
                    "#a5d6a7",
                    "#c8e6c9"
                ]
            },
            "title": "State"
        },
        "opacity": {
            "condition": {
                "param": "state_select",
                "value": 1
            },
            "value": 0.35
        },
        "tooltip": [
            {
                "field": "state_name",
                "title": "State"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            },
            {
                "field": "percent_protected",
                "title": "% Protected",
                "format": ".2f"
            }
        ]
    },
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}