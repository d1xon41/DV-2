{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 700,
    "height": 500,
    "projection": {
        "type": "mercator"
    },
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
                "format": {
                    "type": "json",
                    "property": "features"
                }
            },
            "transform": [
                {
                    "lookup": "properties.STATE_NAME",
                    "from": {
                        "data": {
                            "url": "data/parks_by_jurisdiction.csv"
                        },
                        "key": "state_name",
                        "fields": [
                            "percent_protected",
                            "number_of_parks",
                            "protected_area_ha"
                        ]
                    }
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "#ffffff",
                "strokeWidth": 1
            },
            "encoding": {
                "color": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "title": "% Land Protected"
                },
                "tooltip": [
                    {
                        "field": "properties.STATE_NAME",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "percent_protected",
                        "type": "quantitative",
                        "title": "% Protected"
                    },
                    {
                        "field": "number_of_parks",
                        "type": "quantitative",
                        "title": "Number of Parks"
                    },
                    {
                        "field": "protected_area_ha",
                        "type": "quantitative",
                        "title": "Protected Area (ha)",
                        "format": ","
                    }
                ]
            }
        },
        {
            "data": {
                "url": "data/state_centroids.csv"
            },
            "mark": {
                "type": "circle",
                "opacity": 0.65,
                "color": "#1a4a2e",
                "stroke": "#ffffff",
                "strokeWidth": 1
            },
            "encoding": {
                "longitude": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "latitude",
                    "type": "quantitative"
                },
                "size": {
                    "field": "number_of_parks",
                    "type": "quantitative",
                    "title": "Number of Parks",
                    "scale": {
                        "range": [
                            80,
                            3500
                        ]
                    },
                    "legend": {
                        "orient": "bottom-right"
                    }
                },
                "tooltip": [
                    {
                        "field": "state_name",
                        "title": "State"
                    },
                    {
                        "field": "number_of_parks",
                        "title": "Number of Parks",
                        "format": ","
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Land Protected"
                    },
                    {
                        "field": "protected_area_ha",
                        "title": "Protected Area (ha)",
                        "format": ","
                    }
                ]
            }
        }
    ],
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}