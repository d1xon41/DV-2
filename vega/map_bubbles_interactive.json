{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 700,
    "height": 500,
    "projection": {
        "type": "mercator"
    },
    "data": {
        "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
        "format": {
            "type": "json",
            "property": "features"
        }
    },
    "params": [
        {
            "name": "state_highlight",
            "select": {
                "type": "point",
                "fields": [
                    "properties.STATE_NAME"
                ]
            }
        }
    ],
    "transform": [
        {
            "lookup": "properties.STATE_NAME",
            "from": {
                "data": {
                    "url": "data/parks_by_jurisdiction.csv"
                },
                "key": "state_name",
                "fields": [
                    "percent_protected",
                    "number_of_parks",
                    "protected_area_ha"
                ]
            }
        }
    ],
    "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1,
        "cursor": "pointer"
    },
    "encoding": {
        "color": {
            "condition": {
                "param": "state_highlight",
                "field": "percent_protected",
                "type": "quantitative",
                "scale": {
                    "scheme": "greens"
                },
                "title": "% Land Protected"
            },
            "value": "#e0e0e0"
        },
        "opacity": {
            "condition": {
                "param": "state_highlight",
                "value": 1
            },
            "value": 0.4
        },
        "tooltip": [
            {
                "field": "properties.STATE_NAME",
                "type": "nominal",
                "title": "State"
            },
            {
                "field": "percent_protected",
                "type": "quantitative",
                "title": "% Protected"
            },
            {
                "field": "number_of_parks",
                "type": "quantitative",
                "title": "Number of Parks"
            },
            {
                "field": "protected_area_ha",
                "type": "quantitative",
                "title": "Protected Area (ha)",
                "format": ","
            }
        ]
    }
}