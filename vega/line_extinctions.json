{
    "width": 450,
    "height": 300,
    "data": {
        "url": "data/extinctions.csv"
    },
    "transform": [
        {
            "fold": [
                "mammals",
                "birds",
                "reptiles",
                "frogs"
            ],
            "as": [
                "group",
                "extinctions"
            ]
        }
    ],
    "params": [
        {
            "name": "group_select",
            "select": {
                "type": "point",
                "fields": [
                    "group"
                ]
            },
            "bind": "legend"
        }
    ],
    "mark": {
        "type": "line",
        "point": {
            "filled": true,
            "size": 80
        }
    },
    "encoding": {
        "x": {
            "field": "decade",
            "type": "ordinal",
            "title": "Decade",
            "axis": {
                "grid": false
            }
        },
        "y": {
            "field": "extinctions",
            "type": "quantitative",
            "title": "Number of Extinctions",
            "axis": {
                "grid": false
            }
        },
        "color": {
            "field": "group",
            "type": "nominal",
            "title": "Animal Group",
            "scale": {
                "domain": [
                    "mammals",
                    "birds",
                    "reptiles",
                    "frogs"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d7a3a",
                    "#66bb6a",
                    "#a5d6a7"
                ]
            }
        },
        "opacity": {
            "condition": {
                "param": "group_select",
                "value": 1
            },
            "value": 0.15
        },
        "tooltip": [
            {
                "field": "decade",
                "title": "Decade"
            },
            {
                "field": "group",
                "title": "Group"
            },
            {
                "field": "extinctions",
                "title": "Extinctions"
            }
        ]
    },
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}