{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 450,
    "height": 300,
    "background": "#ede3cc",
    "data": {
        "url": "data/extinctions.csv"
    },
    "transform": [
        {
            "fold": [
                "mammals",
                "birds",
                "reptiles",
                "frogs"
            ],
            "as": [
                "group",
                "extinctions"
            ]
        }
    ],
    "params": [
        {
            "name": "group_select",
            "select": {
                "type": "point",
                "fields": [
                    "group"
                ]
            },
            "bind": "legend"
        },
        {
            "name": "decade_hover",
            "select": {
                "type": "point",
                "nearest": true,
                "on": "mouseover",
                "encodings": [
                    "x"
                ],
                "clear": "mouseout"
            }
        }
    ],
    "layer": [
        {
            "mark": {
                "type": "area",
                "interpolate": "monotone"
            },
            "encoding": {
                "x": {
                    "field": "decade",
                    "type": "ordinal",
                    "title": "Decade",
                    "axis": {
                        "grid": false,
                        "labelColor": "#3d3020",
                        "titleColor": "#3d3020"
                    }
                },
                "y": {
                    "field": "extinctions",
                    "type": "quantitative",
                    "stack": "center",
                    "axis": {
                        "grid": false,
                        "labels": false,
                        "title": null
                    }
                },
                "color": {
                    "field": "group",
                    "type": "nominal",
                    "title": "Animal Group",
                    "scale": {
                        "domain": [
                            "mammals",
                            "birds",
                            "reptiles",
                            "frogs"
                        ],
                        "range": [
                            "#1a4a2e",
                            "#2d7a3a",
                            "#66bb6a",
                            "#a5d6a7"
                        ]
                    }
                },
                "opacity": {
                    "condition": {
                        "param": "group_select",
                        "value": 0.9
                    },
                    "value": 0.15
                },
                "tooltip": [
                    {
                        "field": "decade",
                        "title": "Decade"
                    },
                    {
                        "field": "group",
                        "title": "Group"
                    },
                    {
                        "field": "extinctions",
                        "title": "Extinctions"
                    }
                ]
            }
        },
        {
            "transform": [
                {
                    "filter": {
                        "param": "decade_hover",
                        "empty": false
                    }
                }
            ],
            "mark": {
                "type": "rule",
                "color": "#3d3020",
                "strokeWidth": 1.5,
                "strokeDash": [
                    4,
                    2
                ]
            },
            "encoding": {
                "x": {
                    "field": "decade",
                    "type": "ordinal"
                }
            }
        },
        {
            "transform": [
                {
                    "filter": {
                        "param": "decade_hover",
                        "empty": false
                    }
                },
                {
                    "aggregate": [
                        {
                            "op": "sum",
                            "field": "extinctions",
                            "as": "total_this_decade"
                        }
                    ],
                    "groupby": [
                        "decade"
                    ]
                }
            ],
            "mark": {
                "type": "text",
                "dy": -130,
                "fontSize": 12,
                "fontWeight": "bold",
                "color": "#1a1208"
            },
            "encoding": {
                "x": {
                    "field": "decade",
                    "type": "ordinal"
                },
                "text": {
                    "field": "total_this_decade",
                    "type": "quantitative"
                }
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "axis": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "gridColor": "#d4c9a8"
        },
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}