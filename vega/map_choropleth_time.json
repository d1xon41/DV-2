{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Growth of Protected Areas by State (2000–2020)",
    "width": 700,
    "height": 480,
    "background": "#ede3cc",
    "params": [
        {
            "name": "year_selection",
            "value": 2000,
            "bind": {
                "input": "range",
                "min": 2000,
                "max": 2020,
                "step": 5,
                "name": "Year: "
            }
        }
    ],
    "projection": {
        "type": "mercator",
        "center": [
            133,
            -27
        ],
        "scale": 800
    },
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
                "format": {
                    "type": "json",
                    "property": "features"
                }
            },
            "transform": [
                {
                    "calculate": "'No data for ' + datum.properties.STATE_NAME",
                    "as": "note"
                }
            ],
            "mark": {
                "type": "geoshape",
                "fill": "#ddd",
                "stroke": "#ffffff",
                "strokeWidth": 1
            },
            "encoding": {
                "tooltip": {
                    "field": "note",
                    "type": "nominal"
                }
            }
        },
        {
            "data": {
                "url": "data/protection_growth.csv"
            },
            "transform": [
                {
                    "lookup": "state_name",
                    "from": {
                        "data": {
                            "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
                            "format": {
                                "type": "json",
                                "property": "features"
                            }
                        },
                        "key": "properties.STATE_NAME"
                    },
                    "as": "geo"
                },
                {
                    "filter": "datum.year == year_selection"
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "#ffffff",
                "strokeWidth": 1
            },
            "encoding": {
                "shape": {
                    "field": "geo",
                    "type": "geojson"
                },
                "color": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "title": "% Land Protected",
                    "scale": {
                        "domain": [
                            5,
                            60
                        ],
                        "scheme": "greens"
                    },
                    "legend": {
                        "format": ".1f"
                    }
                },
                "tooltip": [
                    {
                        "field": "state_name",
                        "title": "State"
                    },
                    {
                        "field": "year",
                        "title": "Year"
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "number_of_parks",
                        "title": "Number of Parks",
                        "format": ","
                    }
                ]
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 600,
            "easing": "cubic-in-out"
        }
    }
}