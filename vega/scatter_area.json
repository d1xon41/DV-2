{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "params": [
        {
            "name": "brush",
            "select": {
                "type": "interval"
            }
        }
    ],
    "mark": {
        "type": "point",
        "filled": true,
        "size": 150,
        "cursor": "crosshair"
    },
    "encoding": {
        "x": {
            "field": "jurisdiction_area_ha",
            "type": "quantitative",
            "title": "Total State Area (ha)",
            "scale": {
                "type": "log"
            },
            "axis": {
                "grid": false
            }
        },
        "y": {
            "field": "protected_area_ha",
            "type": "quantitative",
            "title": "Protected Area (ha)",
            "scale": {
                "type": "log"
            },
            "axis": {
                "grid": false
            }
        },
        "color": {
            "condition": {
                "param": "brush",
                "field": "percent_protected",
                "type": "quantitative",
                "scale": {
                    "scheme": "greens"
                },
                "title": "% Protected"
            },
            "value": "#e0e0e0"
        },
        "size": {
            "field": "number_of_parks",
            "type": "quantitative",
            "title": "Number of Parks"
        },
        "opacity": {
            "condition": {
                "param": "brush",
                "value": 1
            },
            "value": 0.2
        },
        "tooltip": [
            {
                "field": "state",
                "title": "State"
            },
            {
                "field": "percent_protected",
                "title": "% Protected",
                "format": ".2f"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            },
            {
                "field": "protected_area_ha",
                "title": "Protected Area (ha)",
                "format": ","
            }
        ]
    },
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}