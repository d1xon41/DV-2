{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "mark": {
        "type": "point",
        "filled": true,
        "size": 150
    },
    "encoding": {
        "x": {
            "field": "jurisdiction_area_ha",
            "type": "quantitative",
            "title": "Total State Area (ha)",
            "scale": {
                "type": "log"
            },
            "axis": {
                "grid": false
            }
        },
        "y": {
            "field": "protected_area_ha",
            "type": "quantitative",
            "title": "Protected Area (ha)",
            "scale": {
                "type": "log"
            },
            "axis": {
                "grid": false
            }
        },
        "color": {
            "field": "percent_protected",
            "type": "quantitative",
            "scale": {
                "scheme": "greens"
            },
            "title": "% Protected"
        },
        "size": {
            "field": "number_of_parks",
            "type": "quantitative",
            "title": "Number of Parks"
        },
        "tooltip": [
            {
                "field": "state_name",
                "title": "State"
            },
            {
                "field": "percent_protected",
                "title": "% Protected"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            },
            {
                "field": "protected_area_ha",
                "title": "Protected Area (ha)",
                "format": ","
            },
            {
                "field": "jurisdiction_area_ha",
                "title": "Total Area (ha)",
                "format": ","
            }
        ]
    }
}