{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 420,
    "height": 300,
    "background": "#ede3cc",
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "transform": [
        {
            "calculate": "datum.percent_protected / 60 * 100",
            "as": "% Protected (norm)"
        },
        {
            "calculate": "datum.contribution_to_nrs * 2",
            "as": "NRS Contribution (norm)"
        },
        {
            "calculate": "datum.number_of_parks / 47.09",
            "as": "Park Count (norm)"
        },
        {
            "calculate": "datum.protected_area_ha / 860000",
            "as": "Protected Area (norm)"
        },
        {
            "fold": [
                "% Protected (norm)",
                "NRS Contribution (norm)",
                "Park Count (norm)",
                "Protected Area (norm)"
            ],
            "as": [
                "metric",
                "value"
            ]
        }
    ],
    "params": [
        {
            "name": "state_hover",
            "select": {
                "type": "point",
                "on": "mouseover",
                "fields": [
                    "state"
                ]
            }
        }
    ],
    "mark": {
        "type": "line",
        "point": {
            "filled": true,
            "size": 50
        }
    },
    "encoding": {
        "x": {
            "field": "metric",
            "type": "nominal",
            "title": null,
            "sort": [
                "% Protected (norm)",
                "NRS Contribution (norm)",
                "Park Count (norm)",
                "Protected Area (norm)"
            ],
            "axis": {
                "labelAngle": -12,
                "labelFontSize": 10,
                "grid": false
            }
        },
        "y": {
            "field": "value",
            "type": "quantitative",
            "title": "Relative Score (0–100)",
            "axis": {
                "grid": false
            }
        },
        "color": {
            "condition": {
                "param": "state_hover",
                "field": "state",
                "type": "nominal",
                "scale": {
                    "domain": [
                        "ACT",
                        "NSW",
                        "NT",
                        "QLD",
                        "SA",
                        "TAS",
                        "VIC",
                        "WA"
                    ],
                    "range": [
                        "#1a4a2e",
                        "#2d6a3e",
                        "#3d8a50",
                        "#4da062",
                        "#66bb6a",
                        "#81c784",
                        "#a5d6a7",
                        "#c8e6c9"
                    ]
                },
                "legend": {
                    "title": "State"
                }
            },
            "value": "#c8b898"
        },
        "detail": {
            "field": "state"
        },
        "opacity": {
            "condition": {
                "param": "state_hover",
                "value": 1
            },
            "value": 0.2
        },
        "tooltip": [
            {
                "field": "state",
                "title": "State"
            },
            {
                "field": "metric",
                "title": "Metric"
            },
            {
                "field": "value",
                "title": "Score",
                "format": ".1f"
            }
        ]
    },
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}