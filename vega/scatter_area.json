{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 420,
    "height": 300,
    "background": "#ede3cc",
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "transform": [
        {
            "calculate": "datum.percent_protected / 60 * 100",
            "as": "pct_norm"
        },
        {
            "calculate": "datum.contribution_to_nrs * 2",
            "as": "nrs_norm"
        },
        {
            "calculate": "datum.number_of_parks / 47.09",
            "as": "count_norm"
        },
        {
            "calculate": "datum.protected_area_ha / 860000",
            "as": "area_norm"
        },
        {
            "fold": [
                "pct_norm",
                "nrs_norm",
                "count_norm",
                "area_norm"
            ],
            "as": [
                "metric",
                "value"
            ]
        },
        {
            "calculate": "datum.metric === 'pct_norm' ? '% Protected' : datum.metric === 'nrs_norm' ? 'NRS Contribution' : datum.metric === 'count_norm' ? 'Park Count' : 'Protected Area'",
            "as": "metric_label"
        }
    ],
    "params": [
        {
            "name": "state_highlight",
            "value": "All",
            "bind": {
                "input": "select",
                "options": [
                    "All",
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "labels": [
                    "All States",
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "name": "Highlight State: "
            }
        }
    ],
    "mark": {
        "type": "line",
        "point": {
            "filled": true,
            "size": 60
        }
    },
    "encoding": {
        "x": {
            "field": "metric_label",
            "type": "nominal",
            "title": null,
            "sort": [
                "% Protected",
                "NRS Contribution",
                "Park Count",
                "Protected Area"
            ],
            "axis": {
                "labelAngle": -12,
                "labelFontSize": 10,
                "grid": false,
                "labelColor": "#3d3020"
            }
        },
        "y": {
            "field": "value",
            "type": "quantitative",
            "title": "Relative Score (0–100)",
            "axis": {
                "grid": false,
                "labelColor": "#3d3020",
                "titleColor": "#3d3020"
            }
        },
        "color": {
            "field": "state",
            "type": "nominal",
            "scale": {
                "domain": [
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d6a3e",
                    "#3d8a50",
                    "#4da062",
                    "#66bb6a",
                    "#81c784",
                    "#a5d6a7",
                    "#c8e6c9"
                ]
            },
            "legend": {
                "title": "State"
            }
        },
        "detail": {
            "field": "state"
        },
        "strokeWidth": {
            "condition": {
                "test": "state_highlight === 'All' || datum.state === state_highlight",
                "value": 3
            },
            "value": 0.8
        },
        "opacity": {
            "condition": {
                "test": "state_highlight === 'All' || datum.state === state_highlight",
                "value": 1
            },
            "value": 0.1
        },
        "tooltip": [
            {
                "field": "state",
                "title": "State"
            },
            {
                "field": "metric_label",
                "title": "Metric"
            },
            {
                "field": "value",
                "title": "Score",
                "format": ".1f"
            }
        ]
    },
    "config": {
        "background": "#ede3cc",
        "axis": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "gridColor": "#d4c9a8"
        },
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}