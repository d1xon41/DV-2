{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 380,
    "height": 280,
    "background": "#ede3cc",
    "data": {
        "url": "data/land_use_marimekko.csv"
    },
    "params": [
        {
            "name": "segment_hover",
            "select": {
                "type": "point",
                "on": "mouseover",
                "fields": [
                    "land_use"
                ]
            }
        }
    ],
    "mark": {
        "type": "rect",
        "cursor": "pointer",
        "stroke": "#ede3cc",
        "strokeWidth": 2
    },
    "encoding": {
        "x": {
            "field": "x_start",
            "type": "quantitative",
            "title": "Cumulative % of Australia's Land",
            "axis": {
                "grid": false
            }
        },
        "x2": {
            "field": "x_end"
        },
        "y": {
            "datum": 0
        },
        "y2": {
            "field": "area_million_ha",
            "type": "quantitative"
        },
        "color": {
            "field": "land_use",
            "type": "nominal",
            "title": "Land Use",
            "scale": {
                "domain": [
                    "Grazing",
                    "Nature Conservation",
                    "Other",
                    "Forestry",
                    "Agriculture",
                    "Urban"
                ],
                "range": [
                    "#8b6914",
                    "#1a4a2e",
                    "#a09070",
                    "#4a7c3f",
                    "#c9a227",
                    "#7a3420"
                ]
            }
        },
        "opacity": {
            "condition": {
                "param": "segment_hover",
                "value": 1
            },
            "value": 0.5
        },
        "tooltip": [
            {
                "field": "land_use",
                "title": "Land Use"
            },
            {
                "field": "area_million_ha",
                "title": "Area (million ha)",
                "format": ".1f"
            },
            {
                "field": "percentage",
                "title": "% of Australia",
                "format": ".1f"
            }
        ]
    },
    "config": {
        "background": "#ede3cc",
        "axis": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "gridColor": "#d4c9a8"
        },
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}