{
    "width": 400,
    "height": 400,
    "data": {
        "url": "data/parks_by_bioregion.csv"
    },
    "params": [
        {
            "name": "hover",
            "select": {
                "type": "point",
                "on": "mouseover",
                "fields": [
                    "bioregion"
                ]
            }
        }
    ],
    "layer": [
        {
            "mark": "rule",
            "encoding": {
                "y": {
                    "field": "bioregion",
                    "type": "nominal",
                    "sort": "-x",
                    "title": "Bioregion"
                },
                "x": {
                    "field": "area_protected_ha",
                    "type": "quantitative",
                    "title": "Protected Area (ha)",
                    "axis": {
                        "grid": false
                    }
                },
                "x2": {
                    "datum": 0
                },
                "color": {
                    "value": "#c8e6c9"
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "size": 100
            },
            "encoding": {
                "y": {
                    "field": "bioregion",
                    "type": "nominal",
                    "sort": "-x"
                },
                "x": {
                    "field": "area_protected_ha",
                    "type": "quantitative"
                },
                "color": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "title": "% Protected"
                },
                "size": {
                    "condition": {
                        "param": "hover",
                        "value": 200
                    },
                    "value": 100
                },
                "tooltip": [
                    {
                        "field": "bioregion",
                        "title": "Bioregion"
                    },
                    {
                        "field": "area_protected_ha",
                        "title": "Protected Area (ha)",
                        "format": ","
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "ibra_area_ha",
                        "title": "Total Bioregion Area (ha)",
                        "format": ","
                    }
                ]
            }
        }
    ],
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}