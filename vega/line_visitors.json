{
    "data": {
        "url": "data/park_visitors.csv"
    },
    "vconcat": [
        {
            "width": 500,
            "height": 250,
            "title": "Visitor Trends — Selected Period",
            "mark": {
                "type": "line",
                "point": {
                    "filled": true,
                    "size": 80
                }
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "quantitative",
                    "title": "Year",
                    "scale": {
                        "domain": {
                            "param": "year_brush"
                        }
                    },
                    "axis": {
                        "format": "d",
                        "grid": false
                    }
                },
                "y": {
                    "field": "visitors",
                    "type": "quantitative",
                    "title": "Annual Visitors",
                    "axis": {
                        "grid": false
                    }
                },
                "color": {
                    "field": "park",
                    "type": "nominal",
                    "title": "National Park",
                    "scale": {
                        "range": [
                            "#1a4a2e",
                            "#2d7a3a",
                            "#81c784"
                        ]
                    }
                },
                "tooltip": [
                    {
                        "field": "park",
                        "title": "Park"
                    },
                    {
                        "field": "year",
                        "title": "Year"
                    },
                    {
                        "field": "visitors",
                        "title": "Visitors",
                        "format": ","
                    }
                ]
            }
        },
        {
            "width": 500,
            "height": 60,
            "title": "Drag to filter years",
            "params": [
                {
                    "name": "year_brush",
                    "select": {
                        "type": "interval",
                        "encodings": [
                            "x"
                        ]
                    }
                }
            ],
            "mark": "line",
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "quantitative",
                    "title": "",
                    "axis": {
                        "format": "d"
                    }
                },
                "y": {
                    "field": "visitors",
                    "type": "quantitative",
                    "axis": {
                        "tickCount": 3,
                        "grid": false
                    },
                    "title": ""
                },
                "color": {
                    "field": "park",
                    "type": "nominal",
                    "legend": null,
                    "scale": {
                        "range": [
                            "#1a4a2e",
                            "#2d7a3a",
                            "#81c784"
                        ]
                    }
                }
            }
        }
    ],
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}