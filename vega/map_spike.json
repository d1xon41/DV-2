{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 700,
    "height": 500,
    "background": "#ede3cc",
    "params": [
        {
            "name": "spike_metric",
            "value": "number_of_parks",
            "bind": {
                "input": "radio",
                "options": [
                    "number_of_parks",
                    "percent_protected",
                    "protected_area_ha"
                ],
                "labels": [
                    "Number of Parks",
                    "% Land Protected",
                    "Protected Area (ha)"
                ],
                "name": "Spike height shows: "
            }
        }
    ],
    "projection": {
        "type": "mercator",
        "center": [
            133,
            -27
        ],
        "scale": 800
    },
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson"
            },
            "mark": {
                "type": "geoshape",
                "fill": "#d4c9a8",
                "stroke": "#a09070",
                "strokeWidth": 1
            }
        },
        {
            "data": {
                "url": "data/state_centroids.csv"
            },
            "transform": [
                {
                    "calculate": "spike_metric === 'number_of_parks' ? datum.number_of_parks : spike_metric === 'percent_protected' ? datum.percent_protected : datum.protected_area_ha",
                    "as": "spike_value"
                }
            ],
            "mark": {
                "type": "rule",
                "strokeCap": "round",
                "strokeWidth": 14
            },
            "encoding": {
                "longitude": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "latitude",
                    "type": "quantitative"
                },
                "longitude2": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude2": {
                    "field": "lat_tip",
                    "type": "quantitative"
                },
                "color": {
                    "field": "spike_value",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "title": "Value"
                },
                "tooltip": [
                    {
                        "field": "state_name",
                        "title": "State"
                    },
                    {
                        "field": "number_of_parks",
                        "title": "Number of Parks",
                        "format": ","
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Land Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "protected_area_ha",
                        "title": "Protected Area (ha)",
                        "format": ","
                    }
                ]
            }
        },
        {
            "data": {
                "url": "data/state_centroids.csv"
            },
            "mark": {
                "type": "text",
                "dy": -8,
                "fontSize": 11,
                "fontWeight": "bold",
                "color": "#1a1208"
            },
            "encoding": {
                "longitude": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "lat_tip",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state",
                    "type": "nominal"
                }
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}