{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 300,
    "height": 350,
    "data": {
        "url": "data/protection_slope.csv"
    },
    "params": [
        {
            "name": "state_hover",
            "select": {
                "type": "point",
                "on": "mouseover",
                "fields": [
                    "state"
                ]
            }
        }
    ],
    "layer": [
        {
            "mark": "line",
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal",
                    "title": null,
                    "axis": {
                        "grid": false
                    }
                },
                "y": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "title": "% Land Protected",
                    "axis": {
                        "grid": false
                    }
                },
                "detail": {
                    "field": "state",
                    "type": "nominal"
                },
                "color": {
                    "condition": {
                        "param": "state_hover",
                        "field": "state",
                        "type": "nominal",
                        "legend": null
                    },
                    "value": "#c8e6c9"
                },
                "size": {
                    "condition": {
                        "param": "state_hover",
                        "value": 3
                    },
                    "value": 1.5
                },
                "opacity": {
                    "condition": {
                        "param": "state_hover",
                        "value": 1
                    },
                    "value": 0.4
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "size": 80
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal"
                },
                "y": {
                    "field": "percent_protected",
                    "type": "quantitative"
                },
                "color": {
                    "condition": {
                        "param": "state_hover",
                        "field": "state",
                        "type": "nominal",
                        "legend": null
                    },
                    "value": "#c8e6c9"
                },
                "opacity": {
                    "condition": {
                        "param": "state_hover",
                        "value": 1
                    },
                    "value": 0.4
                },
                "tooltip": [
                    {
                        "field": "state",
                        "title": "State"
                    },
                    {
                        "field": "year",
                        "title": "Year"
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Protected",
                        "format": ".2f"
                    }
                ]
            }
        },
        {
            "mark": {
                "type": "text",
                "align": "left",
                "dx": 6,
                "fontSize": 11
            },
            "transform": [
                {
                    "filter": "datum.year == 2020"
                }
            ],
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal"
                },
                "y": {
                    "field": "percent_protected",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state",
                    "type": "nominal"
                },
                "opacity": {
                    "condition": {
                        "param": "state_hover",
                        "value": 1
                    },
                    "value": 0.3
                },
                "color": {
                    "condition": {
                        "param": "state_hover",
                        "field": "state",
                        "type": "nominal",
                        "legend": null
                    },
                    "value": "#aaa"
                }
            }
        }
    ],
    "config": {
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}