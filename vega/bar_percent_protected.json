{
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "params": [
        {
            "name": "hover_percent_protected",
            "select": {
                "type": "point",
                "on": "mouseover",
                "fields": [
                    "state"
                ]
            }
        }
    ],
    "layer": [
        {
            "mark": "rule",
            "encoding": {
                "y": {
                    "field": "state",
                    "type": "nominal",
                    "sort": "-x",
                    "title": "State"
                },
                "x": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "title": "% of State Land Protected",
                    "axis": {
                        "grid": false
                    }
                },
                "x2": {
                    "datum": 0
                },
                "color": {
                    "value": "#a5d6a7"
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "size": 150
            },
            "encoding": {
                "y": {
                    "field": "state",
                    "type": "nominal",
                    "sort": "-x"
                },
                "x": {
                    "field": "percent_protected",
                    "type": "quantitative"
                },
                "color": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "legend": null
                },
                "size": {
                    "condition": {
                        "param": "hover_percent_protected",
                        "value": 250
                    },
                    "value": 150
                },
                "tooltip": [
                    {
                        "field": "state",
                        "title": "State"
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "number_of_parks",
                        "title": "Number of Parks",
                        "format": ","
                    }
                ]
            }
        }
    ],
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}