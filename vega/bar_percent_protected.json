{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 300,
    "height": 350,
    "background": "#ede3cc",
    "data": {
        "url": "data/protection_slope.csv"
    },
    "params": [
        {
            "name": "state_selection",
            "value": "All",
            "bind": {
                "input": "select",
                "options": [
                    "All",
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "labels": [
                    "All States",
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "name": "Highlight State: "
            }
        }
    ],
    "layer": [
        {
            "mark": "line",
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal",
                    "title": null,
                    "axis": {
                        "grid": false
                    }
                },
                "y": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "title": "% Land Protected",
                    "axis": {
                        "grid": false
                    }
                },
                "detail": {
                    "field": "state"
                },
                "color": {
                    "field": "state",
                    "type": "nominal",
                    "scale": {
                        "domain": [
                            "ACT",
                            "NSW",
                            "NT",
                            "QLD",
                            "SA",
                            "TAS",
                            "VIC",
                            "WA"
                        ],
                        "range": [
                            "#1a4a2e",
                            "#2d6a3e",
                            "#3d8a50",
                            "#4da062",
                            "#66bb6a",
                            "#81c784",
                            "#a5d6a7",
                            "#c8e6c9"
                        ]
                    },
                    "legend": null
                },
                "strokeWidth": {
                    "condition": {
                        "test": "state_selection === 'All' || datum.state === state_selection",
                        "value": 3
                    },
                    "value": 1
                },
                "opacity": {
                    "condition": {
                        "test": "state_selection === 'All' || datum.state === state_selection",
                        "value": 1
                    },
                    "value": 0.12
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "size": 80
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal"
                },
                "y": {
                    "field": "percent_protected",
                    "type": "quantitative"
                },
                "color": {
                    "field": "state",
                    "type": "nominal",
                    "scale": {
                        "domain": [
                            "ACT",
                            "NSW",
                            "NT",
                            "QLD",
                            "SA",
                            "TAS",
                            "VIC",
                            "WA"
                        ],
                        "range": [
                            "#1a4a2e",
                            "#2d6a3e",
                            "#3d8a50",
                            "#4da062",
                            "#66bb6a",
                            "#81c784",
                            "#a5d6a7",
                            "#c8e6c9"
                        ]
                    },
                    "legend": null
                },
                "opacity": {
                    "condition": {
                        "test": "state_selection === 'All' || datum.state === state_selection",
                        "value": 1
                    },
                    "value": 0.05
                },
                "tooltip": [
                    {
                        "field": "state",
                        "title": "State"
                    },
                    {
                        "field": "year",
                        "title": "Year"
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Protected",
                        "format": ".2f"
                    }
                ]
            }
        },
        {
            "mark": {
                "type": "text",
                "align": "left",
                "dx": 6,
                "fontSize": 11
            },
            "transform": [
                {
                    "filter": "datum.year == 2020"
                },
                {
                    "filter": "state_selection === 'All' || datum.state === state_selection"
                }
            ],
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal"
                },
                "y": {
                    "field": "percent_protected",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state"
                },
                "color": {
                    "field": "state",
                    "type": "nominal",
                    "scale": {
                        "domain": [
                            "ACT",
                            "NSW",
                            "NT",
                            "QLD",
                            "SA",
                            "TAS",
                            "VIC",
                            "WA"
                        ],
                        "range": [
                            "#1a4a2e",
                            "#2d6a3e",
                            "#3d8a50",
                            "#4da062",
                            "#66bb6a",
                            "#81c784",
                            "#a5d6a7",
                            "#c8e6c9"
                        ]
                    }
                }
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "axis": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020"
        },
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}