{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 500,
    "height": 300,
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "mark": "bar",
    "encoding": {
        "y": {
            "field": "state",
            "type": "nominal",
            "title": "State",
            "sort": "-x"
        },
        "x": {
            "field": "percent_protected",
            "type": "quantitative",
            "title": "% of State Land Protected"
        },
        "color": {
            "field": "percent_protected",
            "type": "quantitative",
            "scale": {
                "scheme": "greens"
            },
            "legend": null
        },
        "tooltip": [
            {
                "field": "state",
                "title": "State"
            },
            {
                "field": "percent_protected",
                "title": "% Protected"
            }
        ]
    }
}