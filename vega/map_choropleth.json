{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 700,
    "height": 480,
    "background": "#ede3cc",
    "params": [
        {
            "name": "map_metric",
            "value": "percent_protected",
            "bind": {
                "input": "radio",
                "options": [
                    "percent_protected",
                    "number_of_parks",
                    "protected_area_ha",
                    "contribution_to_nrs"
                ],
                "labels": [
                    "% Land Protected",
                    "Number of Parks",
                    "Protected Area (ha)",
                    "% Contribution to NRS"
                ],
                "name": "Colour by: "
            }
        }
    ],
    "projection": {
        "type": "mercator",
        "center": [
            133,
            -27
        ],
        "scale": 800
    },
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
                "format": {
                    "type": "json",
                    "property": "features"
                }
            },
            "transform": [
                {
                    "lookup": "properties.STATE_NAME",
                    "from": {
                        "data": {
                            "url": "data/parks_by_jurisdiction.csv"
                        },
                        "key": "state_name",
                        "fields": [
                            "percent_protected",
                            "number_of_parks",
                            "protected_area_ha",
                            "contribution_to_nrs",
                            "state"
                        ]
                    }
                },
                {
                    "calculate": "map_metric === 'percent_protected' ? datum.percent_protected : map_metric === 'number_of_parks' ? datum.number_of_parks : map_metric === 'protected_area_ha' ? datum.protected_area_ha : datum.contribution_to_nrs",
                    "as": "selected_value"
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "#ffffff",
                "strokeWidth": 1,
                "cursor": "pointer"
            },
            "encoding": {
                "color": {
                    "field": "selected_value",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "title": "Selected Metric"
                },
                "tooltip": [
                    {
                        "field": "properties.STATE_NAME",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "percent_protected",
                        "type": "quantitative",
                        "title": "% Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "number_of_parks",
                        "type": "quantitative",
                        "title": "Number of Parks",
                        "format": ","
                    },
                    {
                        "field": "protected_area_ha",
                        "type": "quantitative",
                        "title": "Protected Area (ha)",
                        "format": ","
                    },
                    {
                        "field": "contribution_to_nrs",
                        "type": "quantitative",
                        "title": "% Contribution to NRS",
                        "format": ".2f"
                    }
                ]
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}