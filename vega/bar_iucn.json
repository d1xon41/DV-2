{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_iucn.csv"
    },
    "params": [
        {
            "name": "category_select",
            "select": {
                "type": "point",
                "fields": [
                    "iucn_category"
                ]
            }
        }
    ],
    "mark": {
        "type": "circle",
        "cursor": "pointer"
    },
    "encoding": {
        "x": {
            "field": "iucn_category",
            "type": "nominal",
            "title": "IUCN Category",
            "axis": {
                "grid": false
            }
        },
        "y": {
            "field": "number_of_parks",
            "type": "quantitative",
            "title": "Number of Protected Areas",
            "axis": {
                "grid": false
            }
        },
        "size": {
            "field": "area_ha",
            "type": "quantitative",
            "title": "Area (ha)",
            "scale": {
                "range": [
                    100,
                    5000
                ]
            }
        },
        "color": {
            "condition": {
                "param": "category_select",
                "field": "contribution_to_nrs",
                "type": "quantitative",
                "scale": {
                    "scheme": "greens"
                },
                "title": "% Contribution to NRS"
            },
            "value": "#e0e0e0"
        },
        "opacity": {
            "condition": {
                "param": "category_select",
                "value": 1
            },
            "value": 0.3
        },
        "tooltip": [
            {
                "field": "iucn_category",
                "title": "IUCN Category"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            },
            {
                "field": "area_ha",
                "title": "Area (ha)",
                "format": ","
            },
            {
                "field": "contribution_to_nrs",
                "title": "% Contribution to NRS"
            }
        ]
    },
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}