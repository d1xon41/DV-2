{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_iucn.csv"
    },
    "mark": {
        "type": "circle"
    },
    "encoding": {
        "x": {
            "field": "iucn_category",
            "type": "nominal",
            "title": "IUCN Category",
            "axis": {
                "grid": false
            }
        },
        "y": {
            "field": "number_of_parks",
            "type": "quantitative",
            "title": "Number of Protected Areas",
            "axis": {
                "grid": false
            }
        },
        "size": {
            "field": "area_ha",
            "type": "quantitative",
            "title": "Area (ha)",
            "scale": {
                "range": [
                    100,
                    5000
                ]
            }
        },
        "color": {
            "field": "contribution_to_nrs",
            "type": "quantitative",
            "scale": {
                "scheme": "greens"
            },
            "title": "% Contribution to NRS"
        },
        "tooltip": [
            {
                "field": "iucn_category",
                "title": "IUCN Category"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            },
            {
                "field": "area_ha",
                "title": "Area (ha)",
                "format": ","
            },
            {
                "field": "contribution_to_nrs",
                "title": "% Contribution to NRS"
            }
        ]
    }
}