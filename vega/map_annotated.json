{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 700,
    "height": 480,
    "background": "#ede3cc",
    "projection": {
        "type": "mercator",
        "center": [
            133,
            -27
        ],
        "scale": 800
    },
    "params": [
        {
            "name": "final_map_click",
            "select": {
                "type": "point",
                "fields": [
                    "properties.STATE_NAME"
                ]
            }
        }
    ],
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
                "format": {
                    "type": "json",
                    "property": "features"
                }
            },
            "transform": [
                {
                    "lookup": "properties.STATE_NAME",
                    "from": {
                        "data": {
                            "url": "data/parks_by_jurisdiction.csv"
                        },
                        "key": "state_name",
                        "fields": [
                            "percent_protected",
                            "number_of_parks"
                        ]
                    }
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "#ffffff",
                "strokeWidth": 1,
                "cursor": "pointer"
            },
            "encoding": {
                "color": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "title": "% Land Protected"
                },
                "strokeWidth": {
                    "condition": {
                        "param": "final_map_click",
                        "value": 3
                    },
                    "value": 1
                },
                "tooltip": [
                    {
                        "field": "properties.STATE_NAME",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "percent_protected",
                        "type": "quantitative",
                        "title": "% Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "number_of_parks",
                        "type": "quantitative",
                        "title": "Number of Parks",
                        "format": ","
                    }
                ]
            }
        },
        {
            "data": {
                "url": "data/state_centroids.csv"
            },
            "mark": {
                "type": "text",
                "fontSize": 12,
                "fontWeight": "bold",
                "dy": -8
            },
            "encoding": {
                "longitude": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "latitude",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state",
                    "type": "nominal"
                },
                "color": {
                    "value": "#1a1208"
                }
            }
        },
        {
            "data": {
                "url": "data/state_centroids.csv"
            },
            "mark": {
                "type": "text",
                "fontSize": 10,
                "dy": 8,
                "fontStyle": "italic"
            },
            "encoding": {
                "longitude": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "latitude",
                    "type": "quantitative"
                },
                "text": {
                    "field": "percent_protected",
                    "type": "quantitative",
                    "format": ".1f"
                },
                "color": {
                    "value": "#3d3020"
                }
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}