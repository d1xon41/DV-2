{
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_jurisdiction.csv"
    },
    "layer": [
        {
            "mark": "rule",
            "encoding": {
                "y": {
                    "field": "state",
                    "type": "nominal",
                    "sort": "-x",
                    "title": "State"
                },
                "x": {
                    "field": "number_of_parks",
                    "type": "quantitative",
                    "title": "Number of Protected Areas",
                    "axis": {
                        "grid": false
                    }
                },
                "x2": {
                    "datum": 0
                },
                "color": {
                    "value": "#c8e6c9"
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "size": 120
            },
            "encoding": {
                "y": {
                    "field": "state",
                    "type": "nominal",
                    "sort": "-x"
                },
                "x": {
                    "field": "number_of_parks",
                    "type": "quantitative"
                },
                "color": {
                    "field": "number_of_parks",
                    "type": "quantitative",
                    "scale": {
                        "scheme": "greens"
                    },
                    "legend": null
                },
                "size": {
                    "value": 120
                },
                "tooltip": [
                    {
                        "field": "state",
                        "title": "State"
                    },
                    {
                        "field": "number_of_parks",
                        "title": "Number of Parks",
                        "format": ","
                    },
                    {
                        "field": "percent_protected",
                        "title": "% Protected",
                        "format": ".2f"
                    }
                ]
            }
        }
    ],
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}