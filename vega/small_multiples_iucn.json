{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 320,
    "height": 260,
    "background": "#ede3cc",
    "data": {
        "url": "data/iucn_by_state.csv"
    },
    "params": [
        {
            "name": "heatmap_state",
            "value": "All",
            "bind": {
                "input": "select",
                "options": [
                    "All",
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "labels": [
                    "All States",
                    "ACT",
                    "NSW",
                    "NT",
                    "QLD",
                    "SA",
                    "TAS",
                    "VIC",
                    "WA"
                ],
                "name": "Compare State: "
            }
        }
    ],
    "transform": [
        {
            "filter": "heatmap_state === 'All' || datum.state === heatmap_state"
        }
    ],
    "mark": {
        "type": "rect",
        "cursor": "pointer",
        "stroke": "#ede3cc",
        "strokeWidth": 2,
        "cornerRadius": 3
    },
    "encoding": {
        "x": {
            "field": "iucn_category",
            "type": "ordinal",
            "title": "IUCN Category",
            "axis": {
                "labelAngle": 0,
                "labelColor": "#3d3020",
                "titleColor": "#3d3020"
            }
        },
        "y": {
            "field": "state",
            "type": "nominal",
            "title": "State",
            "axis": {
                "labelColor": "#3d3020",
                "titleColor": "#3d3020"
            }
        },
        "color": {
            "field": "number_of_parks",
            "type": "quantitative",
            "scale": {
                "scheme": "greens"
            },
            "title": "Parks"
        },
        "tooltip": [
            {
                "field": "state",
                "title": "State"
            },
            {
                "field": "iucn_category",
                "title": "IUCN Category"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            }
        ]
    },
    "config": {
        "background": "#ede3cc",
        "view": {
            "stroke": null
        },
        "axis": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "gridColor": "#d4c9a8"
        },
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}