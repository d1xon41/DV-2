{
    "data": {
        "url": "data/iucn_by_state.csv"
    },
    "params": [
        {
            "name": "hover_multiples_iucn",
            "select": {
                "type": "point",
                "on": "mouseover",
                "fields": [
                    "iucn_category"
                ]
            }
        }
    ],
    "facet": {
        "field": "state",
        "type": "nominal",
        "title": "IUCN Category Breakdown by State",
        "columns": 4
    },
    "spec": {
        "width": 120,
        "height": 100,
        "mark": {
            "type": "bar",
            "cursor": "pointer"
        },
        "encoding": {
            "x": {
                "field": "iucn_category",
                "type": "nominal",
                "title": null,
                "axis": {
                    "labelAngle": 0
                }
            },
            "y": {
                "field": "number_of_parks",
                "type": "quantitative",
                "title": "Parks"
            },
            "color": {
                "field": "iucn_category",
                "type": "nominal",
                "scale": {
                    "scheme": "greens"
                },
                "legend": null
            },
            "opacity": {
                "condition": {
                    "param": "hover_multiples_iucn",
                    "value": 1
                },
                "value": 0.4
            },
            "tooltip": [
                {
                    "field": "state",
                    "title": "State"
                },
                {
                    "field": "iucn_category",
                    "title": "IUCN Category"
                },
                {
                    "field": "number_of_parks",
                    "title": "Number of Parks",
                    "format": ","
                }
            ]
        }
    },
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}