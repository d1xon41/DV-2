{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 350,
    "height": 280,
    "data": {
        "url": "data/iucn_by_state.csv"
    },
    "params": [
        {
            "name": "cell_select",
            "select": {
                "type": "point",
                "fields": [
                    "state",
                    "iucn_category"
                ]
            }
        }
    ],
    "mark": {
        "type": "rect",
        "cursor": "pointer",
        "cornerRadius": 4
    },
    "encoding": {
        "x": {
            "field": "iucn_category",
            "type": "ordinal",
            "title": "IUCN Category",
            "axis": {
                "labelAngle": 0
            }
        },
        "y": {
            "field": "state",
            "type": "nominal",
            "title": "State"
        },
        "color": {
            "condition": {
                "param": "cell_select",
                "field": "number_of_parks",
                "type": "quantitative",
                "scale": {
                    "scheme": "greens"
                },
                "title": "Number of Parks"
            },
            "value": "#f0f0f0"
        },
        "opacity": {
            "condition": {
                "param": "cell_select",
                "value": 1
            },
            "value": 0.4
        },
        "tooltip": [
            {
                "field": "state",
                "title": "State"
            },
            {
                "field": "iucn_category",
                "title": "IUCN Category"
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            }
        ]
    },
    "config": {
        "transition": {
            "duration": 400,
            "easing": "cubic-in-out"
        }
    }
}