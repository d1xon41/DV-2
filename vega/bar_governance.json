{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 300,
    "height": 300,
    "data": {
        "url": "data/parks_by_governance.csv"
    },
    "mark": {
        "type": "arc",
        "innerRadius": 60,
        "outerRadius": 130
    },
    "encoding": {
        "theta": {
            "field": "area_ha",
            "type": "quantitative"
        },
        "radius": {
            "field": "contribution_to_nrs",
            "type": "quantitative",
            "scale": {
                "rangeMin": 60,
                "rangeMax": 130
            }
        },
        "color": {
            "field": "governance_type",
            "type": "nominal",
            "title": "Governance Type",
            "scale": {
                "domain": [
                    "Community",
                    "Government",
                    "Joint",
                    "Private"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d7a3a",
                    "#66bb6a",
                    "#a5d6a7"
                ]
            }
        },
        "tooltip": [
            {
                "field": "governance_type",
                "title": "Governance Type"
            },
            {
                "field": "area_ha",
                "title": "Area (ha)",
                "format": ","
            },
            {
                "field": "contribution_to_nrs",
                "title": "% Contribution to NRS"
            }
        ]
    }
}