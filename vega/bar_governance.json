{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 400,
    "height": 300,
    "data": {
        "url": "data/parks_by_governance.csv"
    },
    "params": [
        {
            "name": "gov_select",
            "select": {
                "type": "point",
                "fields": [
                    "governance_type"
                ]
            }
        }
    ],
    "mark": {
        "type": "arc",
        "innerRadius": 60,
        "outerRadius": 130,
        "cursor": "pointer"
    },
    "encoding": {
        "theta": {
            "field": "area_ha",
            "type": "quantitative"
        },
        "radius": {
            "field": "contribution_to_nrs",
            "type": "quantitative",
            "scale": {
                "rangeMin": 60,
                "rangeMax": 130
            }
        },
        "color": {
            "field": "governance_type",
            "type": "nominal",
            "title": "Governance Type",
            "scale": {
                "domain": [
                    "Community",
                    "Government",
                    "Joint",
                    "Private"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d7a3a",
                    "#66bb6a",
                    "#a5d6a7"
                ]
            }
        },
        "opacity": {
            "condition": {
                "param": "gov_select",
                "value": 1
            },
            "value": 0.3
        },
        "tooltip": [
            {
                "field": "governance_type",
                "title": "Governance Type"
            },
            {
                "field": "area_ha",
                "title": "Area (ha)",
                "format": ","
            },
            {
                "field": "number_of_parks",
                "title": "Number of Areas",
                "format": ","
            },
            {
                "field": "contribution_to_nrs",
                "title": "% Contribution to NRS",
                "format": ".2f"
            }
        ]
    },
    "config": {
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}