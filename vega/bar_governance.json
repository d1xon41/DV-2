{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 300,
    "height": 300,
    "background": "#ede3cc",
    "data": {
        "url": "data/parks_by_governance.csv"
    },
    "params": [
        {
            "name": "gov_metric",
            "value": "area_ha",
            "bind": {
                "input": "radio",
                "options": [
                    "area_ha",
                    "number_of_parks"
                ],
                "labels": [
                    "Land Area (ha)",
                    "Number of Parks"
                ],
                "name": "Show: "
            }
        }
    ],
    "transform": [
        {
            "calculate": "gov_metric === 'area_ha' ? datum.area_ha : datum.number_of_parks",
            "as": "gov_value"
        }
    ],
    "mark": {
        "type": "arc",
        "innerRadius": 60,
        "stroke": "#ede3cc",
        "strokeWidth": 3,
        "cursor": "pointer"
    },
    "encoding": {
        "theta": {
            "field": "gov_value",
            "type": "quantitative"
        },
        "color": {
            "field": "governance_type",
            "type": "nominal",
            "title": "Governance",
            "scale": {
                "domain": [
                    "Community",
                    "Government",
                    "Joint",
                    "Private"
                ],
                "range": [
                    "#1a4a2e",
                    "#2d7a3a",
                    "#66bb6a",
                    "#a5d6a7"
                ]
            }
        },
        "tooltip": [
            {
                "field": "governance_type",
                "title": "Governance Type"
            },
            {
                "field": "area_ha",
                "title": "Area (ha)",
                "format": ","
            },
            {
                "field": "number_of_parks",
                "title": "Number of Parks",
                "format": ","
            },
            {
                "field": "contribution_to_nrs",
                "title": "% Contribution to NRS",
                "format": ".2f"
            }
        ]
    },
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}