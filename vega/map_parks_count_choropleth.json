{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 700,
    "height": 480,
    "background": "#ede3cc",
    "params": [
        {
            "name": "compare_mode",
            "value": "absolute",
            "bind": {
                "input": "radio",
                "options": [
                    "absolute",
                    "relative"
                ],
                "labels": [
                    "Absolute count",
                    "Above / below national average (22.6%)"
                ],
                "name": "View: "
            }
        }
    ],
    "projection": {
        "type": "mercator",
        "center": [
            133,
            -27
        ],
        "scale": 800
    },
    "layer": [
        {
            "data": {
                "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/refs/heads/master/states.geojson",
                "format": {
                    "type": "json",
                    "property": "features"
                }
            },
            "transform": [
                {
                    "lookup": "properties.STATE_NAME",
                    "from": {
                        "data": {
                            "url": "data/parks_by_jurisdiction.csv"
                        },
                        "key": "state_name",
                        "fields": [
                            "number_of_parks",
                            "percent_protected",
                            "state"
                        ]
                    }
                },
                {
                    "calculate": "compare_mode === 'absolute' ? datum.number_of_parks : datum.percent_protected - 22.6",
                    "as": "display_value"
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "#ffffff",
                "strokeWidth": 1
            },
            "encoding": {
                "color": {
                    "field": "display_value",
                    "type": "quantitative",
                    "scale": {
                        "scheme": {
                            "expr": "compare_mode === 'relative' ? 'redyellowgreen' : 'greens'"
                        },
                        "domainMid": {
                            "expr": "compare_mode === 'relative' ? 0 : null"
                        }
                    },
                    "title": {
                        "expr": "compare_mode === 'absolute' ? 'Number of Parks' : 'Difference from 22.6% average'"
                    }
                },
                "tooltip": [
                    {
                        "field": "properties.STATE_NAME",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "number_of_parks",
                        "type": "quantitative",
                        "title": "Number of Parks",
                        "format": ","
                    },
                    {
                        "field": "percent_protected",
                        "type": "quantitative",
                        "title": "% Protected",
                        "format": ".2f"
                    },
                    {
                        "field": "display_value",
                        "type": "quantitative",
                        "title": "Displayed Value",
                        "format": ".2f"
                    }
                ]
            }
        }
    ],
    "config": {
        "background": "#ede3cc",
        "legend": {
            "labelColor": "#3d3020",
            "titleColor": "#3d3020",
            "fillColor": "#ede3cc"
        },
        "transition": {
            "duration": 500,
            "easing": "cubic-in-out"
        }
    }
}